;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PTI-Doodle"
run/main_scene="uid://dran7ic7i4odi"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/images/icon.svg"

[autoload]

